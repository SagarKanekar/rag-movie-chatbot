{
  "version": 2,
  "builds": [
    { "src": "api/index.py", "use": "@vercel/python" },
    { "src": "index.html", "use": "@vercel/static" }
  ],
  "routes": [
    { "src": "/chat", "methods": ["GET", "POST"], "dest": "/api/index.py" },
    { "src": "/", "dest": "/index.html" },
    { "src": "/(styles\\.css|script\\.js)", "dest": "/$1" },
    { "src": "/api/(.*)", "dest": "/api/$1" }
  ]
}
